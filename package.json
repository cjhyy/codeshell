    "@types/node": "^22.12.0",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
