{
  "name": "@cjhyy/code-shell",
  "version": "0.5.0-rc.0",
  "description": "Code Shell — meta package. Installs @cjhyy/code-shell-core and @cjhyy/code-shell-tui.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "code-shell": "./node_modules/.bin/code-shell"
  },
  "scripts": {
    "preinstall": "node scripts/check-node.cjs",
    "build": "mkdir -p dist && printf 'export * from \"@cjhyy/code-shell-core\";\n' > dist/index.js && printf 'export * from \"@cjhyy/code-shell-core\";\n' > dist/index.d.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages/",
    "format": "prettier --write 'packages/**/*.ts'"
  },
  "dependencies": {
    "@cjhyy/code-shell-core": "workspace:*",
    "@cjhyy/code-shell-tui": "workspace:*"
  },
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjhyy/codeshell.git"
  },
  "homepage": "https://github.com/cjhyy/codeshell#readme",
  "bugs": {
    "url": "https://github.com/cjhyy/codeshell/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.10"
  },
  "files": [
    "dist",
    "scripts/check-node.cjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "coding-assistant",
    "cli",
    "claude-code",
    "mcp",
    "llm"
  ],
  "author": "maki maki",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.12.0",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "bun-types": "^1.3.14",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0"
  }
}
