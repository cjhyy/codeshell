{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "react/compiler-runtime": ["src/react-compiler-runtime-shim.ts"],
      "src/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "src/agent/*.ts",
    "src/arena/*.ts",
    "src/bootstrap/*.ts",
    "src/cli/**/*.ts",
    "src/context/compaction.ts",
    "src/context/token-counter.ts",
    "src/context/manager.ts",
    "src/cron/*.ts",
    "src/engine/*.ts",
    "src/git/*.ts",
    "src/hooks/events.ts",
    "src/hooks/registry.ts",
    "src/ink/**/*.ts",
    "src/ink/**/*.tsx",
    "src/llm/**/*.ts",
    "src/logging/*.ts",
    "src/lsp/*.ts",
    "src/native-ts/**/*.ts",
    "src/plugins/loader.ts",
    "src/plugins/types.ts",
    "src/preset/*.ts",
    "src/prompt/*.ts",
    "src/prompt/sections/md.d.ts",
    "src/protocol/*.ts",
    "src/remote/bridge.ts",
    "src/session/*.ts",
    "src/settings/*.ts",
    "src/services/analytics.ts",
    "src/services/auto-dream.ts",
    "src/services/compact.ts",
    "src/services/diagnostics.ts",
    "src/services/extract-memories.ts",
    "src/services/index.ts",
    "src/services/notifier.ts",
    "src/services/oauth.ts",
    "src/services/session-memory.ts",
    "src/skills/*.ts",
    "src/tool-system/**/*.ts",
    "src/ui/**/*.ts",
    "src/ui/**/*.tsx",
    "src/utils/*.ts",
    "src/product/**/*.ts",
    "src/run/**/*.ts",
    "src/voice/*.ts",
    "src/exceptions.ts",
    "src/index.ts",
    "src/types.ts",
    "src/react-compiler-runtime-shim.ts"
  ],
  "exclude": ["node_modules", "dist", "tests"]
}
