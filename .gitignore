node_modules/
dist/
*.tsbuildinfo
.env
.env.local
.env.*.local
logs/
log/
*.log
.DS_Store
coverage/
.vscode/
.idea/
pnpm-lock.yaml

# Agent run artifacts
examples/prd-agent/output/*
!examples/prd-agent/output/.gitkeep
examples/prismo-agent/output/
examples/*/.runs/
.code-shell/

# Test outputs (AI news drafts, slides, codex research, PPT/PDF
# artifacts). Tools like scripts/gen-recent-pptx.ts write here; the
# contents are throwaway. Keep the directory marker so the path exists.
docs/test-outputs/*
!docs/test-outputs/.gitkeep
out/

# superpowers skills' local runtime state (PID/log/events files per
# brainstorm session). Pure machine-local — every run regenerates.
# Brainstorm "content/" output (HTML/MD artifacts) is intentionally
# allowed through.
.superpowers/brainstorm/*/state/

# Claude Code session state: worktrees created by EnterWorktree / git
# worktree add live here. Local only — never commit worktree contents.
.claude/worktrees/
packages/desktop/.preview/
