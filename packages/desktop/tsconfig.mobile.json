{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@ui/*": ["src/renderer/components/ui/*"],
      "@protocol": ["../server/src/mobile-remote/types.ts"],
      "@mobile/*": ["src/mobile/*"],
      "@cjhyy/code-shell-web": ["../web/src/index.ts"],
      "@cjhyy/code-shell-web/*": ["../web/src/*"]
    }
  },
  "include": [
    "src/mobile",
    "src/renderer/components/ui",
    "src/renderer/lib",
    "../server/src/mobile-remote/types.ts"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
