{
  "name": "@cjhyy/code-shell-desktop",
  "version": "0.5.0-rc.0",
  "private": true,
  "description": "Electron desktop client for code-shell (POC).",
  "type": "module",
  "main": "./out/main/index.mjs",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=esm --outfile=out/main/index.mjs --external:electron --loader:.md=text --banner:js=\"import { createRequire as __ccr } from 'node:module'; const require = __ccr(import.meta.url);\"",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=out/preload/index.cjs --external:electron",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron ."
  },
  "dependencies": {
    "@cjhyy/code-shell-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.0",
    "typescript": "^5.7.3",
    "vite": "^7.0.0"
  }
}
