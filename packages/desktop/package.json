{
  "name": "@cjhyy/code-shell-desktop",
  "version": "0.5.0-rc.2",
  "private": true,
  "description": "Electron desktop client for code-shell (POC).",
  "type": "module",
  "main": "./out/main/index.mjs",
  "scripts": {
    "postinstall": "bun run rebuild:native",
    "rebuild:native": "bun run scripts/rebuild-native.ts",
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=esm --outfile=out/main/index.mjs --external:electron --external:@cjhyy/code-shell-core --loader:.md=text --banner:js=\"import { createRequire as __ccr } from 'node:module'; const require = __ccr(import.meta.url);\"",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=out/preload/index.cjs --external:electron",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.cjhyy.codeshell",
    "productName": "code-shell",
    "files": [
      "out/**/*",
      "build/icon.png",
      "package.json",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [
      {
        "from": "../../examples/agents",
        "to": "examples/agents"
      },
      {
        "from": "resources/known-marketplaces-seed.json",
        "to": "packages/desktop/resources/known-marketplaces-seed.json"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@cjhyy/code-shell-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11",
    "lucide-react": "^0.460.0",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react-markdown": "^9",
    "rehype-highlight": "^7",
    "rehype-raw": "^7",
    "rehype-sanitize": "^6",
    "remark-gfm": "^4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "playwright": "^1.60.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "vite": "^7.0.0"
  }
}
