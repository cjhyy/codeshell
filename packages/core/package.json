{
  "name": "@cjhyy/code-shell-core",
  "version": "0.6.0",
  "description": "Core engine for code-shell — agent orchestration, tool execution, hooks, protocol. UI-agnostic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bin/agent-server-stdio": "./dist/cli/agent-server-stdio.js"
  },
  "sideEffects": [
    "./dist/data/*.json",
    "./dist/prompt/sections/*.md"
  ],
  "//files": "LICENSE/README intentionally omitted: npm/bun always include them in a publish regardless of this list, so the published tarball is unchanged — but listing them makes electron-builder (which follows the workspace symlink when packaging the desktop app) try to copy them from packages/core, tripping its 'file must be under <app>' guard (electron-builder#3238). dist is all the desktop bundle needs.",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && bun run copy-assets",
    "copy-assets": "node ../../scripts/copy-assets.mjs dist/prompt/sections src/prompt/sections/*.md && node ../../scripts/copy-assets.mjs dist/data src/data/*.json",
    "dev": "bun run copy-assets && tsc -p tsconfig.json --watch --preserveWatchOutput",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "glob": "^11.0.0",
    "gpt-tokenizer": "^3.4.0",
    "nanoid": "^5.1.2",
    "openai": "^4.82.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "strip-ansi": "^7.2.0",
    "yaml": "^2.7.0",
    "yauzl": "^3.4.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=20.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjhyy/codeshell.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cjhyy/codeshell/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/cjhyy/codeshell/issues"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "agent-framework",
    "claude-code",
    "claude",
    "openai",
    "anthropic",
    "mcp",
    "llm",
    "tool-use",
    "function-calling",
    "headless"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/yauzl": "^3.4.0"
  }
}
