{
  "name": "@cjhyy/code-shell-cli",
  "version": "0.4.0-poc.0",
  "description": "Terminal UI for code-shell — Ink-based REPL on top of @cjhyy/code-shell-core.",
  "type": "module",
  "main": "./dist/index.js",
